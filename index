<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Experience Value Model (XVM)</title>

  <style>
    :root {
      --green: #00B956;
      --purple: #731982;
      --border: #D2D5DA;
      --muted: #8F96A4;
      --field: #F2F4F7;
      --bg: #F8F9FB;
      --text: #1B1F27;
      --white: #FFFFFF;
      --danger: #D92D20;
      --gradient: linear-gradient(90deg, #00B956 0%, #00D2FF 100%);
      --shadow: 0 10px 30px rgba(19, 27, 45, 0.06);
      --radius-xl: 24px;
      --radius-lg: 18px;
      --radius-md: 14px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family:
        "MegaFon Graphik LC Regular",
        "MegaFon Graphik LC Light",
        "MegaFon Graphik LC Medium",
        "MegaFon Graphik LC Semibold",
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        Arial,
        sans-serif;
      line-height: 1.4;
    }

    .container {
      max-width: 1320px;
      margin: 0 auto;
      padding: 32px 20px 64px;
    }

    .page-title {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 28px;
      font-family: "MegaFon Graphik LC Semibold", sans-serif;
      font-size: 32px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--purple);
      text-align: center;
    }

    .card {
      background: var(--white);
      border: 1px solid rgba(210, 213, 218, 0.7);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      padding: 28px;
      margin-bottom: 22px;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 0 0 22px;
      font-size: 28px;
      font-family: "MegaFon Graphik LC Semibold", sans-serif;
    }

    .section-title::before {
      content: "";
      width: 5px;
      height: 28px;
      border-radius: 999px;
      background: var(--purple);
      display: inline-block;
    }

    .subhint {
      margin: -8px 0 20px;
      color: var(--muted);
      font-size: 14px;
    }

    .grid-3,
    .grid-4 {
      display: grid;
      gap: 18px;
      margin-bottom: 18px;
    }

    .grid-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .grid-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-width: 0;
    }

    .field label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-family: "MegaFon Graphik LC Medium", sans-serif;
    }

    input,
    select {
      width: 100%;
      border: 1px solid transparent;
      background: var(--field);
      border-radius: var(--radius-md);
      padding: 16px 18px;
      min-height: 54px;
      font-size: 16px;
      color: var(--text);
      outline: none;
      transition: 0.2s ease;
      font-family: "MegaFon Graphik LC Regular", sans-serif;
    }

    input:focus,
    select:focus {
      border-color: rgba(115, 25, 130, 0.35);
      box-shadow: 0 0 0 4px rgba(115, 25, 130, 0.08);
      background: #fff;
    }

    .metric-box {
      background: linear-gradient(180deg, #fff 0%, #faf7fc 100%);
      border: 1px solid rgba(115, 25, 130, 0.12);
      border-radius: var(--radius-lg);
      padding: 18px 20px;
      min-height: 92px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .metric-box .label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    .metric-box .value {
      font-size: 34px;
      line-height: 1;
      color: var(--purple);
      font-family: "MegaFon Graphik LC Semibold", sans-serif;
    }

    .metric-box .value.green {
      color: var(--green);
    }

    .toolbar {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .btn {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text);
      border-radius: 14px;
      padding: 14px 18px;
      font-size: 15px;
      cursor: pointer;
      min-height: 48px;
      transition: 0.2s ease;
      font-family: "MegaFon Graphik LC Medium", sans-serif;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(19, 27, 45, 0.08);
    }

    .btn-primary {
      background: var(--green);
      border-color: var(--green);
      color: #fff;
    }

    .btn-secondary {
      background: #fff;
      color: var(--purple);
      border-color: rgba(115, 25, 130, 0.16);
    }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
    }

    .table-wrap {
      overflow-x: auto;
      border-radius: 18px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 1100px;
    }

    thead th {
      text-align: left;
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 0 10px 10px;
      font-family: "MegaFon Graphik LC Medium", sans-serif;
    }

    tbody td {
      background: var(--white);
      padding: 8px 10px 14px;
      vertical-align: middle;
      border-bottom: 1px solid #eef1f4;
    }

    .cell-input input,
    .cell-input select {
      min-height: 50px;
      padding: 14px;
      font-size: 15px;
    }

    .readonly-pill {
      min-height: 50px;
      border-radius: 14px;
      padding: 14px;
      display: flex;
      align-items: center;
      background: #fbfcfd;
      border: 1px solid #edf0f4;
      font-size: 15px;
      white-space: nowrap;
    }

    .readonly-pill.strong {
      font-family: "MegaFon Graphik LC Semibold", sans-serif;
    }

    .readonly-pill.green {
      color: var(--green);
    }

    .readonly-pill.purple {
      color: var(--purple);
    }

    .remove-btn {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--muted);
      cursor: pointer;
      font-size: 18px;
    }

    .remove-btn:hover {
      color: var(--danger);
      border-color: rgba(217, 45, 32, 0.25);
      background: #fff7f6;
    }

    .analysis-toolbar {
      display: grid;
      grid-template-columns: minmax(260px, 360px) 1fr;
      gap: 18px;
      margin-bottom: 20px;
      align-items: end;
    }

    .inline-stats {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      min-height: 54px;
    }

    .inline-stat {
      padding: 10px 14px;
      border-radius: 14px;
      background: #fafbfc;
      border: 1px solid #edf0f4;
      font-size: 14px;
    }

    .inline-stat strong {
      font-family: "MegaFon Graphik LC Semibold", sans-serif;
      color: var(--purple);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-family: "MegaFon Graphik LC Medium", sans-serif;
    }

    .badge.success {
      background: rgba(0, 185, 86, 0.1);
      color: var(--green);
    }

    .badge.muted {
      background: #f2f4f7;
      color: var(--muted);
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
      margin-top: 22px;
    }

    .summary-card {
      border-radius: 18px;
      padding: 18px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      border: 1px solid #edf0f4;
    }

    .summary-card .summary-label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .summary-card .summary-value {
      font-size: 28px;
      line-height: 1.1;
      font-family: "MegaFon Graphik LC Semibold", sans-serif;
      color: var(--text);
    }

    .summary-card .summary-value.purple {
      color: var(--purple);
    }

    .summary-card .summary-value.green {
      color: var(--green);
    }

    .footer-note {
      margin-top: 16px;
      color: var(--muted);
      font-size: 13px;
    }

    @media (max-width: 1100px) {
      .grid-4,
      .summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .analysis-toolbar {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .container {
        padding: 20px 14px 40px;
      }

      .page-title {
        font-size: 22px;
      }

      .card {
        padding: 20px;
      }

      .section-title {
        font-size: 22px;
      }

      .grid-3,
      .grid-4,
      .summary-grid {
        grid-template-columns: 1fr;
      }

      .metric-box .value {
        font-size: 28px;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="page-title">
      <span>💎</span>
      <span>Experience Value Model</span>
    </div>

    <section class="card">
      <h2 class="section-title">1. Глобальные константы сценария</h2>
      <p class="subhint">Базовая экономика продукта и верхнеуровневые параметры сценария.</p>

      <div class="grid-3">
        <div class="field">
          <label for="scenarioStart">Вход в сценарий</label>
          <input id="scenarioStart" type="number" min="0" step="1" placeholder="0" />
        </div>

        <div class="field">
          <label for="scenarioFinal">Финальные сделки</label>
          <input id="scenarioFinal" type="number" min="0" step="1" placeholder="0" />
        </div>

        <div class="metric-box">
          <div class="label">Общая CR сценария</div>
          <div id="totalScenarioCR" class="value green">0%</div>
        </div>
      </div>

      <div class="grid-4">
        <div class="field">
          <label for="aov">AOV, ₽</label>
          <input id="aov" type="number" min="0" step="1" placeholder="0" />
        </div>

        <div class="field">
          <label for="arpu">ARPU, ₽</label>
          <input id="arpu" type="number" min="0" step="1" placeholder="0" />
        </div>

        <div class="field">
          <label for="lt">Lifetime, месяцев</label>
          <input id="lt" type="number" min="0" step="1" placeholder="0" />
        </div>

        <div class="metric-box">
          <div class="label">LTV клиента</div>
          <div id="ltvValue" class="value">0 ₽</div>
        </div>
      </div>
    </section>

    <section class="card">
      <h2 class="section-title">2. Потенциал этапов воронки</h2>
      <p class="subhint">Заполни название этапа, вход и выход. Остальное считается автоматически.</p>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Название этапа</th>
              <th>Вход</th>
              <th>Выход</th>
              <th>Потери</th>
              <th>CR шага</th>
              <th>Downstream CR</th>
              <th>Pot. Deals</th>
              <th>Pot. AOV</th>
              <th>Pot. LTV</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="stagesTableBody"></tbody>
        </table>
      </div>

      <div class="toolbar">
        <button class="btn btn-primary" id="addStageBtn">+ Добавить этап</button>
        <button class="btn btn-secondary" id="fillDemoBtn">Заполнить демо</button>
        <button class="btn btn-ghost" id="clearAllBtn">Очистить всё</button>
      </div>
    </section>

    <section class="card">
      <h2 class="section-title">3. Оценка проблем на этапе</h2>
      <p class="subhint">Денежный потенциал выбранного этапа распределяется между проблемами через friction index.</p>

      <div class="analysis-toolbar">
        <div class="field">
          <label for="stageSelector">Этап для анализа</label>
          <select id="stageSelector"></select>
        </div>

        <div class="inline-stats">
          <div class="inline-stat">Потенциал AOV: <strong id="selectedStageAov">0 ₽</strong></div>
          <div class="inline-stat">Потенциал LTV: <strong id="selectedStageLtv">0 ₽</strong></div>
          <div class="inline-stat">Потери: <strong id="selectedStageLosses">0</strong></div>
          <div class="inline-stat">Downstream CR: <strong id="selectedStageDcr">0%</strong></div>
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Описание проблемы</th>
              <th>Reach</th>
              <th>Impact</th>
              <th>Confidence</th>
              <th>Friction Index</th>
              <th>Статус</th>
              <th>Вес</th>
              <th>AOV Cost</th>
              <th>LTV Cost</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="problemsTableBody"></tbody>
        </table>
      </div>

      <div class="toolbar">
        <button class="btn btn-primary" id="addProblemBtn">+ Добавить проблему</button>
      </div>

      <div class="summary-grid">
        <div class="summary-card">
          <div class="summary-label">Коммерческих проблем</div>
          <div id="commercialCount" class="summary-value purple">0</div>
        </div>

        <div class="summary-card">
          <div class="summary-label">Гигиенических проблем</div>
          <div id="hygieneCount" class="summary-value">0</div>
        </div>

        <div class="summary-card">
          <div class="summary-label">Суммарный Index</div>
          <div id="sumFValue" class="summary-value green">0.000</div>
        </div>

        <div class="summary-card">
          <div class="summary-label">Распределённый LTV</div>
          <div id="distributedLtv" class="summary-value purple">0 ₽</div>
        </div>
      </div>

      <div class="footer-note">
        Если Impact &lt; 0.05, проблема считается гигиенической и не участвует в финансовом распределении.
      </div>
    </section>
  </div>

  <script>
    const reachOptions = [
      { value: 1.0, label: "1.0 Global" },
      { value: 0.5, label: "0.5 Significant" },
      { value: 0.1, label: "0.1 Local" }
    ];

    const impactOptions = [
      { value: 1.0, label: "1.0 Blocker" },
      { value: 0.5, label: "0.5 Critical" },
      { value: 0.2, label: "0.2 Friction" },
      { value: 0.01, label: "0.01 Minor" }
    ];

    const confidenceOptions = [
      { value: 1.0, label: "1.0 Data" },
      { value: 0.7, label: "0.7 Research" },
      { value: 0.2, label: "0.2 Hypothesis" }
    ];

    const state = {
      stages: [],
      problemsByStage: {},
      selectedStageId: null
    };

    const els = {
      scenarioStart: document.getElementById("scenarioStart"),
      scenarioFinal: document.getElementById("scenarioFinal"),
      aov: document.getElementById("aov"),
      arpu: document.getElementById("arpu"),
      lt: document.getElementById("lt"),

      totalScenarioCR: document.getElementById("totalScenarioCR"),
      ltvValue: document.getElementById("ltvValue"),

      stagesTableBody: document.getElementById("stagesTableBody"),
      addStageBtn: document.getElementById("addStageBtn"),
      fillDemoBtn: document.getElementById("fillDemoBtn"),
      clearAllBtn: document.getElementById("clearAllBtn"),

      stageSelector: document.getElementById("stageSelector"),
      selectedStageAov: document.getElementById("selectedStageAov"),
      selectedStageLtv: document.getElementById("selectedStageLtv"),
      selectedStageLosses: document.getElementById("selectedStageLosses"),
      selectedStageDcr: document.getElementById("selectedStageDcr"),

      problemsTableBody: document.getElementById("problemsTableBody"),
      addProblemBtn: document.getElementById("addProblemBtn"),

      commercialCount: document.getElementById("commercialCount"),
      hygieneCount: document.getElementById("hygieneCount"),
      sumFValue: document.getElementById("sumFValue"),
      distributedLtv: document.getElementById("distributedLtv")
    };

    function uid(prefix = "id") {
      return `${prefix}_${Math.random().toString(36).slice(2, 9)}`;
    }

    function n(value) {
      const num = Number(value);
      return Number.isFinite(num) ? num : 0;
    }

    function safeDiv(a, b) {
      return b > 0 ? a / b : 0;
    }

    function formatNumber(value, fractionDigits = 0) {
      return new Intl.NumberFormat("ru-RU", {
        minimumFractionDigits: fractionDigits,
        maximumFractionDigits: fractionDigits
      }).format(n(value));
    }

    function formatPercent(value, fractionDigits = 2) {
      return `${formatNumber(value * 100, fractionDigits)}%`;
    }

    function formatMoney(value) {
      return `${formatNumber(value, 0)} ₽`;
    }

    function escapeHtml(str) {
      return String(str ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function getAov() {
      return n(els.aov.value);
    }

    function getLtv() {
      return n(els.aov.value) + n(els.arpu.value) * n(els.lt.value);
    }

    function renderTopMetrics() {
      const start = n(els.scenarioStart.value);
      const finalDeals = n(els.scenarioFinal.value);
      const totalCR = safeDiv(finalDeals, start);
      const ltv = getLtv();

      els.totalScenarioCR.textContent = formatPercent(totalCR, 2);
      els.ltvValue.textContent = formatMoney(ltv);
    }

    function computeStageMetrics() {
      const stages = state.stages.map(stage => ({
        ...stage,
        input: n(stage.input),
        output: n(stage.output)
      }));

      stages.forEach(stage => {
        stage.losses = Math.max(stage.input - stage.output, 0);
        stage.cr = safeDiv(stage.output, stage.input);
        stage.dcr = 1;
        stage.potentialDeals = 0;
        stage.potentialAov = 0;
        stage.potentialLtv = 0;
      });

      let downstreamCr = 1;

      for (let i = stages.length - 1; i >= 0; i--) {
        stages[i].dcr = downstreamCr;
        downstreamCr *= stages[i].cr;
      }

      const aov = getAov();
      const ltv = getLtv();

      stages.forEach(stage => {
        stage.potentialDeals = stage.losses * stage.dcr;
        stage.potentialAov = stage.potentialDeals * aov;
        stage.potentialLtv = stage.potentialDeals * ltv;
      });

      return stages;
    }

    function getSelectedStageComputed() {
      return computeStageMetrics().find(stage => stage.id === state.selectedStageId) || null;
    }

    function createOptionList(options, selectedValue) {
      return options.map(opt => `
        <option value="${opt.value}" ${Number(opt.value) === Number(selectedValue) ? "selected" : ""}>
          ${opt.label}
        </option>
      `).join("");
    }

    function renderStages() {
      const computed = computeStageMetrics();

      els.stagesTableBody.innerHTML = computed.map(stage => `
        <tr>
          <td class="cell-input">
            <input type="text" value="${escapeHtml(stage.name)}" data-stage-id="${stage.id}" data-field="name" placeholder="Название этапа" />
          </td>

          <td class="cell-input">
            <input type="number" min="0" step="1" value="${stage.input}" data-stage-id="${stage.id}" data-field="input" placeholder="0" />
          </td>

          <td class="cell-input">
            <input type="number" min="0" step="1" value="${stage.output}" data-stage-id="${stage.id}" data-field="output" placeholder="0" />
          </td>

          <td><div class="readonly-pill" data-stage-metric="losses" data-stage-id="${stage.id}">${formatNumber(stage.losses)}</div></td>
          <td><div class="readonly-pill" data-stage-metric="cr" data-stage-id="${stage.id}">${formatPercent(stage.cr, 1)}</div></td>
          <td><div class="readonly-pill strong green" data-stage-metric="dcr" data-stage-id="${stage.id}">${formatPercent(stage.dcr, 2)}</div></td>
          <td><div class="readonly-pill strong" data-stage-metric="potentialDeals" data-stage-id="${stage.id}">${formatNumber(stage.potentialDeals, 0)}</div></td>
          <td><div class="readonly-pill purple" data-stage-metric="potentialAov" data-stage-id="${stage.id}">${formatMoney(stage.potentialAov)}</div></td>
          <td><div class="readonly-pill strong purple" data-stage-metric="potentialLtv" data-stage-id="${stage.id}">${formatMoney(stage.potentialLtv)}</div></td>

          <td>
            <button class="remove-btn" data-remove-stage="${stage.id}" aria-label="Удалить этап">×</button>
          </td>
        </tr>
      `).join("");

      bindStageEvents();
      renderStageSelector();
    }

    function updateStageCalculatedCells() {
      const computed = computeStageMetrics();

      computed.forEach(stage => {
        const metricFormatters = {
          losses: value => formatNumber(value),
          cr: value => formatPercent(value, 1),
          dcr: value => formatPercent(value, 2),
          potentialDeals: value => formatNumber(value, 0),
          potentialAov: value => formatMoney(value),
          potentialLtv: value => formatMoney(value)
        };

        Object.entries(metricFormatters).forEach(([metric, formatter]) => {
          const cell = els.stagesTableBody.querySelector(
            `[data-stage-id="${stage.id}"][data-stage-metric="${metric}"]`
          );

          if (cell) {
            cell.textContent = formatter(stage[metric]);
          }
        });
      });
    }

    function bindStageEvents() {
      els.stagesTableBody.querySelectorAll("input").forEach(input => {
        input.addEventListener("input", e => {
          const id = e.target.dataset.stageId;
          const field = e.target.dataset.field;
          const stage = state.stages.find(s => s.id === id);
          if (!stage) return;

          stage[field] = field === "name" ? e.target.value : n(e.target.value);

          if (field === "name") {
            renderStageSelector();
          } else {
            updateCalculatedViews();
          }
        });
      });

      els.stagesTableBody.querySelectorAll("[data-remove-stage]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.removeStage;
          state.stages = state.stages.filter(s => s.id !== id);
          delete state.problemsByStage[id];

          if (state.selectedStageId === id) {
            state.selectedStageId = state.stages[0]?.id || null;
          }

          rerenderAll();
        });
      });
    }

    function renderStageSelector() {
      const stages = computeStageMetrics();

      if (!stages.length) {
        els.stageSelector.innerHTML = `<option value="">Нет этапов</option>`;
        state.selectedStageId = null;
        return;
      }

      if (!state.selectedStageId || !stages.some(s => s.id === state.selectedStageId)) {
        state.selectedStageId = stages[0].id;
      }

      els.stageSelector.innerHTML = stages.map(stage => `
        <option value="${stage.id}" ${stage.id === state.selectedStageId ? "selected" : ""}>
          ${escapeHtml(stage.name || "Без названия")}
        </option>
      `).join("");
    }

    function renderProblemStageSummary() {
      const stage = getSelectedStageComputed();

      if (!stage) {
        els.selectedStageAov.textContent = formatMoney(0);
        els.selectedStageLtv.textContent = formatMoney(0);
        els.selectedStageLosses.textContent = "0";
        els.selectedStageDcr.textContent = "0%";
        return;
      }

      els.selectedStageAov.textContent = formatMoney(stage.potentialAov);
      els.selectedStageLtv.textContent = formatMoney(stage.potentialLtv);
      els.selectedStageLosses.textContent = formatNumber(stage.losses);
      els.selectedStageDcr.textContent = formatPercent(stage.dcr, 2);
    }

    function getProblemRowsData(problems, stage) {
      const commercialProblems = problems.filter(p => n(p.impact) >= 0.05);
      const sumF = commercialProblems.reduce((acc, p) => acc + n(p.reach) * n(p.impact) * n(p.confidence), 0);

      return problems.map(problem => {
        const frictionIndex = n(problem.reach) * n(problem.impact) * n(problem.confidence);
        const isCommercial = n(problem.impact) >= 0.05;
        const weight = isCommercial && sumF > 0 ? frictionIndex / sumF : 0;

        return {
          problem,
          frictionIndex,
          isCommercial,
          weight,
          aovCost: stage.potentialAov * weight,
          ltvCost: stage.potentialLtv * weight
        };
      });
    }

    function renderProblems() {
      const stage = getSelectedStageComputed();

      if (!stage) {
        els.problemsTableBody.innerHTML = "";
        renderProblemStageSummary();
        renderProblemSummary([]);
        return;
      }

      const problems = state.problemsByStage[state.selectedStageId] || [];
      const rowsData = getProblemRowsData(problems, stage);

      els.problemsTableBody.innerHTML = rowsData.map(row => `
        <tr>
          <td class="cell-input">
            <input type="text" value="${escapeHtml(row.problem.description)}" data-problem-id="${row.problem.id}" data-field="description" placeholder="Описание барьера" />
          </td>

          <td class="cell-input">
            <select data-problem-id="${row.problem.id}" data-field="reach">
              ${createOptionList(reachOptions, row.problem.reach)}
            </select>
          </td>

          <td class="cell-input">
            <select data-problem-id="${row.problem.id}" data-field="impact">
              ${createOptionList(impactOptions, row.problem.impact)}
            </select>
          </td>

          <td class="cell-input">
            <select data-problem-id="${row.problem.id}" data-field="confidence">
              ${createOptionList(confidenceOptions, row.problem.confidence)}
            </select>
          </td>

          <td><div class="readonly-pill strong" data-problem-metric="frictionIndex" data-problem-id="${row.problem.id}">${formatNumber(row.frictionIndex, 3)}</div></td>

          <td data-problem-metric="status" data-problem-id="${row.problem.id}">
            ${getProblemStatusBadge(row.isCommercial)}
          </td>

          <td><div class="readonly-pill" data-problem-metric="weight" data-problem-id="${row.problem.id}">${formatPercent(row.weight, 1)}</div></td>
          <td><div class="readonly-pill purple" data-problem-metric="aovCost" data-problem-id="${row.problem.id}">${formatMoney(row.aovCost)}</div></td>
          <td><div class="readonly-pill strong purple" data-problem-metric="ltvCost" data-problem-id="${row.problem.id}">${formatMoney(row.ltvCost)}</div></td>

          <td>
            <button class="remove-btn" data-remove-problem="${row.problem.id}" aria-label="Удалить проблему">×</button>
          </td>
        </tr>
      `).join("");

      bindProblemEvents();
      renderProblemStageSummary();
      renderProblemSummary(problems);
    }

    function getProblemStatusBadge(isCommercial) {
      return isCommercial
        ? '<span class="badge success">Коммерческая</span>'
        : '<span class="badge muted">Без влияния</span>';
    }

    function updateProblemCalculatedCells() {
      const stage = getSelectedStageComputed();
      const problems = state.problemsByStage[state.selectedStageId] || [];

      if (!stage || !problems.length) {
        renderProblemStageSummary();
        renderProblemSummary(problems);
        return;
      }

      const rowsData = getProblemRowsData(problems, stage);

      rowsData.forEach(row => {
        const metricFormatters = {
          frictionIndex: value => formatNumber(value, 3),
          weight: value => formatPercent(value, 1),
          aovCost: value => formatMoney(value),
          ltvCost: value => formatMoney(value)
        };

        Object.entries(metricFormatters).forEach(([metric, formatter]) => {
          const cell = els.problemsTableBody.querySelector(
            `[data-problem-id="${row.problem.id}"][data-problem-metric="${metric}"]`
          );

          if (cell) {
            cell.textContent = formatter(row[metric]);
          }
        });

        const statusCell = els.problemsTableBody.querySelector(
          `[data-problem-id="${row.problem.id}"][data-problem-metric="status"]`
        );

        if (statusCell) {
          statusCell.innerHTML = getProblemStatusBadge(row.isCommercial);
        }
      });

      renderProblemStageSummary();
      renderProblemSummary(problems);
    }

    function bindProblemEvents() {
      els.problemsTableBody.querySelectorAll("input, select").forEach(input => {
        const isDescription = input.dataset.field === "description";

        if (isDescription) {
          input.addEventListener("input", e => {
            const problem = getProblemById(e.target.dataset.problemId);
            if (problem) problem.description = e.target.value;
          });
        } else {
          input.addEventListener("change", e => {
            const problem = getProblemById(e.target.dataset.problemId);
            if (!problem) return;

            problem[e.target.dataset.field] = Number(e.target.value);
            updateProblemCalculatedCells();
          });
        }
      });

      els.problemsTableBody.querySelectorAll("[data-remove-problem]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.removeProblem;
          state.problemsByStage[state.selectedStageId] =
            (state.problemsByStage[state.selectedStageId] || []).filter(p => p.id !== id);

          renderProblems();
        });
      });
    }

    function getProblemById(id) {
      const list = state.problemsByStage[state.selectedStageId] || [];
      return list.find(problem => problem.id === id);
    }

    function renderProblemSummary(problems) {
      const commercial = problems.filter(p => n(p.impact) >= 0.05);
      const hygiene = problems.filter(p => n(p.impact) < 0.05);
      const sumF = commercial.reduce((acc, p) => acc + n(p.reach) * n(p.impact) * n(p.confidence), 0);
      const stage = getSelectedStageComputed();
      const distributedLtv = commercial.length && stage ? stage.potentialLtv : 0;

      els.commercialCount.textContent = commercial.length;
      els.hygieneCount.textContent = hygiene.length;
      els.sumFValue.textContent = formatNumber(sumF, 3);
      els.distributedLtv.textContent = formatMoney(distributedLtv);
    }

    function updateCalculatedViews() {
      renderTopMetrics();
      updateStageCalculatedCells();
      renderProblemStageSummary();
      updateProblemCalculatedCells();
    }

    function rerenderAll() {
      renderTopMetrics();
      renderStages();
      renderProblems();
    }

    function addStage(stage = null) {
      const newStage = stage || {
        id: uid("stage"),
        name: `Этап ${state.stages.length + 1}`,
        input: 0,
        output: 0
      };

      state.stages.push(newStage);
      state.problemsByStage[newStage.id] = state.problemsByStage[newStage.id] || [];

      if (!state.selectedStageId) {
        state.selectedStageId = newStage.id;
      }

      rerenderAll();
    }

    function addProblem(problem = null) {
      if (!state.selectedStageId) return;

      const newProblem = problem || {
        id: uid("problem"),
        description: "",
        reach: 1.0,
        impact: 0.2,
        confidence: 0.7
      };

      if (!state.problemsByStage[state.selectedStageId]) {
        state.problemsByStage[state.selectedStageId] = [];
      }

      state.problemsByStage[state.selectedStageId].push(newProblem);
      renderProblems();
    }

    function fillDemo() {
      els.scenarioStart.value = 82000;
      els.scenarioFinal.value = 217;
      els.aov.value = 46000;
      els.arpu.value = 3000;
      els.lt.value = 24;

      state.stages = [];
      state.problemsByStage = {};
      state.selectedStageId = null;

      const demoStages = [
        { id: uid("stage"), name: "Визит → Заявка", input: 82000, output: 2535 },
        { id: uid("stage"), name: "Заявка → КП", input: 2535, output: 928 },
        { id: uid("stage"), name: "КП → Сделка", input: 928, output: 217 }
      ];

      demoStages.forEach(stage => {
        state.stages.push(stage);
        state.problemsByStage[stage.id] = [];
      });

      state.selectedStageId = demoStages[2].id;

      state.problemsByStage[demoStages[2].id] = [
        {
          id: uid("problem"),
          description: "Длительное согласование КП",
          reach: 1.0,
          impact: 0.5,
          confidence: 0.7
        },
        {
          id: uid("problem"),
          description: "Разрозненные коммуникации",
          reach: 0.5,
          impact: 0.2,
          confidence: 0.7
        },
        {
          id: uid("problem"),
          description: "Минорная текстовая ошибка",
          reach: 1.0,
          impact: 0.01,
          confidence: 1.0
        }
      ];

      rerenderAll();
    }

    function clearAll() {
      els.scenarioStart.value = "";
      els.scenarioFinal.value = "";
      els.aov.value = "";
      els.arpu.value = "";
      els.lt.value = "";

      state.stages = [];
      state.problemsByStage = {};
      state.selectedStageId = null;

      addStage({
        id: uid("stage"),
        name: "Этап 1",
        input: 0,
        output: 0
      });
    }

    els.addStageBtn.addEventListener("click", () => addStage());
    els.addProblemBtn.addEventListener("click", () => addProblem());
    els.fillDemoBtn.addEventListener("click", fillDemo);
    els.clearAllBtn.addEventListener("click", clearAll);

    els.stageSelector.addEventListener("change", e => {
      state.selectedStageId = e.target.value;
      renderProblems();
    });

    [els.scenarioStart, els.scenarioFinal, els.aov, els.arpu, els.lt].forEach(input => {
      input.addEventListener("input", updateCalculatedViews);
    });

    clearAll();
  </script>
</body>
</html>
